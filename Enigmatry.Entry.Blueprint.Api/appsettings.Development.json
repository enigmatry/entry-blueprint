{
  "UseDeveloperExceptionPage": true,
  "DbContext": {
    "SensitiveDataLoggingEnabled": true,
    "UseAccessToken": false
  },
  "ConnectionStrings": {
    "AppDbContext": "Server=.;Database=enigmatry-entry-blueprint;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
  },
  "App": {
    "Smtp": {
      "UsePickupDirectory": true,
      "PickupDirectoryLocation": "c:/temp/emails"
    },
    "AzureAd": {
      "Instance": "https://enigmatryexternaldev.ciamlogin.com",
      "ClientId": "e11274d2-cc0b-489a-8d79-838bb6136363",
      "TenantId": "fef70c5e-e243-4362-b1bb-00fbce29ea98",
      "Scope": [
        "api://e11274d2-cc0b-489a-8d79-838bb6136363/api"
      ]
      // Needed for SwaggerUI only
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.EntityFrameworkCore": "Information",
        "System": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Logger",
        "Args": {
          "configureLogger": {
            "WriteTo": [
              {
                "Args": {
                  "path": "c:/temp/logs/enigmatry-entry-blueprint-api-.log"
                }
              }
            ]
          }
        }
      },
      {
        "Name": "Logger",
        "Args": {
          "configureLogger": {
            "WriteTo": [
              {
                "Args": {
                  "path": "c:/temp/logs/enigmatry-entry-blueprint-api-security-.log"
                }
              }
            ]
          }
        }
      }
    ]
  },
  "HealthChecks": {
    "MaximumAllowedMemoryInMegaBytes": "200",
    "TokenAuthorizationEnabled": false,
    "RequiredToken": ""
  },
  "KeyVault": {
    "Enabled": false,
    "Name": "enigmatry-entry-blueprint-test"
  }
